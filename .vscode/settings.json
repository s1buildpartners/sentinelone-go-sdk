{
    "go.lintTool": "golangci-lint-v2",
    "go.lintFlags": [
        "--issues-exit-code=0"
    ],
    "go.lintOnSave": "package",
    "gopls": {
        "formatting.gofumpt": true,
        "ui.diagnostic.staticcheck": false,
    },
    "go.testFlags": [
        "-covermode=atomic"
    ],
    "files.associations": {
        "*.mdc": "markdown"
    }
}
